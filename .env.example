# Apex Books Frontend env (copy to .env.local for dev)

# Backend base URL (apex-flow-labs Next.js project)
NEXT_PUBLIC_BACKEND_URL=https://www.apexflowlabs.com

# This site's public URL
NEXT_PUBLIC_SITE_URL=https://books.apexflowlabs.com

# Server-side bearer for the backend /api/v1/* surface
APEX_API_BEARER=replace-with-shared-secret

# Analytics (load only after cookie consent)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL=
NEXT_PUBLIC_CLARITY_ID=
